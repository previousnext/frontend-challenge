{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "arrowParens": "avoid",
  "semi": false,
  "sortPackageJson": false,
  "ignorePatterns": [
    "/node_modules",
    "package.json",
    "package-lock.json",
    "/storybook-static",
    "/storybook",
    "docs/*.md"
  ]
}
