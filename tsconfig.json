{
  "compilerOptions": {
    "esModuleInterop": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "isolatedModules": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2023", "dom", "dom.iterable"],
    "resolveJsonModule": true,
    "types": ["vite/client", "node"]
  },
  "include": ["src", ".storybook/*", ".storybook/**/*", "node_modules/vitest/globals.d.ts"],
  "exclude": ["node_modules"]
}
